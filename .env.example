# Database (Supabase or local Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/avenue

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI (embeddings)
OPENAI_API_KEY=sk-proj-...

# API auth (required by apps/api)
JWT_SECRET=replace-with-long-random-secret
# Web -> API proxy target (used by apps/web route handlers)
AVENUE_API_URL=http://localhost:4000

# Sentry error tracking — create a project at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://...@ingest.sentry.io/...
SENTRY_ORG=avenue
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=

# Environment label shown in Sentry events
NEXT_PUBLIC_ENV=development

# Logging
LOG_LEVEL=debug
SERVICE_NAME=avenue-web
